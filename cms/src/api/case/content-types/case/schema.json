{
  "kind": "collectionType",
  "collectionName": "cases",
  "info": {
    "singularName": "case",
    "pluralName": "cases",
    "displayName": "Case",
    "description": "Kundecases — konkrete AI-projekter hos AIK's kunder"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "description": "Overskrift på casen, fx 'Datasikker HR-agent hos Lavazza'"
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "description": "URL-segmentet — genereres automatisk fra title"
    },
    "customer": {
      "type": "string",
      "required": true,
      "description": "Kundens virksomhedsnavn, fx 'Lavazza'"
    },
    "customerLogo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "enumeration",
      "enum": ["intern-ai", "webshop", "vidensbase", "hr", "andet"],
      "required": true,
      "default": "intern-ai",
      "description": "Kategori — styrer hvor casen vises"
    },
    "challenge": {
      "type": "text",
      "required": true,
      "description": "Hvad udfordringen var før AIK kom ind"
    },
    "solution": {
      "type": "richtext",
      "required": true,
      "description": "Hvordan løsningen blev bygget (markdown)"
    },
    "result": {
      "type": "richtext",
      "required": true,
      "description": "Konkrete resultater, kan være punktliste"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Vis som hovedcase på forsiden"
    },
    "order": {
      "type": "integer",
      "default": 0,
      "description": "Manuel sortering — lavere tal = højere placering"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "seoTitle": {
      "type": "string",
      "description": "SEO-title — override default (max 60 tegn)"
    },
    "seoDescription": {
      "type": "text",
      "description": "SEO-description (max 160 tegn)"
    }
  }
}
