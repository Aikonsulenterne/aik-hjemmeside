{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post",
    "description": "Viden om AI — blog-artikler"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true,
      "maxLength": 300,
      "description": "Kort sammenfatning — vises på listesiden"
    },
    "content": {
      "type": "richtext",
      "required": true,
      "description": "Hovedindhold (markdown)"
    },
    "author": {
      "type": "string",
      "default": "AI Konsulenterne"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "guide",
        "case-story",
        "tech-dive",
        "business-case",
        "compliance",
        "news"
      ],
      "default": "guide"
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "seoTitle": {
      "type": "string",
      "maxLength": 60
    },
    "seoDescription": {
      "type": "text",
      "maxLength": 160
    },
    "keywords": {
      "type": "json",
      "description": "Array af keywords, fx ['AI', 'SMV', 'GDPR']"
    },
    "readingTime": {
      "type": "integer",
      "description": "Estimeret læsetid i minutter"
    }
  }
}
