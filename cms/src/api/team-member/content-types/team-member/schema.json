{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Team Member",
    "description": "Holdet bag AI Konsulenterne"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string",
      "required": true,
      "description": "Titel/rolle, fx 'Grundlægger & AI-konsulent'"
    },
    "bio": {
      "type": "text",
      "description": "Kort bio (1-3 sætninger)"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "linkedinUrl": {
      "type": "string",
      "regex": "^https?://.*linkedin.com/.*"
    },
    "email": {
      "type": "email"
    },
    "order": {
      "type": "integer",
      "required": true,
      "default": 0,
      "description": "Sortering — Alexander skal være 0"
    },
    "isPrimary": {
      "type": "boolean",
      "default": false,
      "description": "Marker Alexander/primær kontaktperson — vises i hero"
    }
  }
}
