{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": "Kunde-citater og anbefalinger"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "quote": {
      "type": "text",
      "required": true,
      "description": "Selve citatet"
    },
    "authorName": {
      "type": "string",
      "required": true
    },
    "authorTitle": {
      "type": "string",
      "required": true,
      "description": "Jobtitel"
    },
    "company": {
      "type": "string",
      "required": true
    },
    "companyLogo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "authorPhoto": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "default": 5
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Vis på forsiden"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
